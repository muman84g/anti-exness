# Python / Environment
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
venv/
ENV/
.env

# Trading data & sensitive configs
live_trades.json
live_config.py
*.log
logs_dump/
build_log*.txt

# IDE / tool files
.vscode/
.idea/
.gemini/
.agent/

# MT5 Binaries & System Data
mt5setup.exe
mt5setup_cache/
mt5_extracted/
*.ex5

# Exclude MQL5 standard library dumps
MQL5_dump/

# Exclude all debug screenshots
*.png

# MetaTrader 5 Folder Strategy
# Ignore everything in MetaTrader 5 except our specific EA source
MetaTrader 5/**
!MetaTrader 5/MQL5/
!MetaTrader 5/MQL5/Experts/
!MetaTrader 5/MQL5/Experts/BotBridge.mq5

# Explicitly ignore system subfolders inside MT5 even if they are in whitelisted paths
MetaTrader 5/Bases/
MetaTrader 5/Logs/
MetaTrader 5/MQL5/Logs/
MetaTrader 5/MQL5/Files/
MetaTrader 5/Tester/
MetaTrader 5/Profiles/
MetaTrader 5/Config/

# Whitelist initialization files if they are in root
!startup.ini
!common.ini
!terminal.ini

# Whitelist documentation
!handover_notes.md
!metaapi_setup_guide.md